{
  "name": "leasehub-operations-console",
  "version": "1.0.0",
  "description": "Fully offline enterprise-grade desktop application (Electron + SQLite + Dear ImGui-style immediate-mode UI).",
  "private": true,
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build":             "npm run build:main && npm run build:renderer",
    "build:main":        "tsc -p tsconfig.main.json",
    "build:renderer":    "vite build",
    "dev":               "vite",
    "start":             "electron .",
    "test":              "npm run test:unit && npm run test:integration",
    "test:unit":         "vitest run unit_tests",
    "test:integration":  "vitest run integration_tests",
    "test:watch":        "vitest",
    "test:docker":       "docker compose run --rm test",
    "docker:up":         "docker compose up --build",
    "docker:build":      "docker compose build",
    "docker:down":       "docker compose down -v",
    "typecheck":         "tsc --noEmit",
    "lint":              "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "drizzle-orm":    "^0.36.0",
    "pino":           "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node":           "^20.0.0",
    "electron":              "^31.0.0",
    "electron-builder":      "^25.0.0",
    "typescript":            "^5.5.0",
    "vite":                  "^5.4.0",
    "vitest":                "^2.0.0"
  }
}
