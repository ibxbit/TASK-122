{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module":           "CommonJS",
    "moduleResolution": "Node",
    "outDir":           "dist/main",
    "rootDir":          "src",
    "types":            ["node"]
  },
  "include": ["src/main/**/*", "src/preload/**/*"],
  "exclude": ["src/renderer/**/*", "node_modules", "dist"]
}
